---
layout: none
permalink: /search.json
---
[
  {% assign items = "" | split: "" %}
  {% for post in site.posts %}
    {% assign items = items | push: post %}
  {% endfor %}
  {% for page in site.pages %}
    {% if page.title and page.url != "/404.html" and page.url != "/search.json" and page.layout != "none" %}
      {% assign items = items | push: page %}
    {% endif %}
  {% endfor %}
  {% for item in items %}
  {
    "title"    : {{ item.title | strip | jsonify }},
    "category" : {{ item.category | strip | jsonify }},
    "tags"     : {{ item.tags | join: ', ' | strip | jsonify }},
    "content"  : {{ item.content | strip_html | strip_newlines | strip | truncate: 500 | jsonify }},
    "url"      : {{ item.url | relative_url | jsonify }},
    "date"     : {{ item.date | date: "%Y-%m-%d" | default: "" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]